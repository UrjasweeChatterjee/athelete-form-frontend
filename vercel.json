{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://athelete-form-backend-production.up.railway.app/api/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://athelete-form-backend-production.up.railway.app/uploads/$1"
    },
    {
      "source": "/((?!api|uploads).*)",
      "destination": "/index.html"
    }
  ]
}